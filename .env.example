# Public URL (for production)
NEXT_PUBLIC_API_URL=https://kelaspekerja.id

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google OAuth (for login)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_TOKEN=your_token

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Java Backend API
NEXT_PUBLIC_JAVA_API_URL=http://localhost:8080/api

# Discord Webhook
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# Vercel Speed Insights
NEXT_PUBLIC_SPEED_INSIGHTS_ENABLED=true

# Feature flags
NEXT_PUBLIC_ENABLE_COMMENTS=false
NEXT_PUBLIC_ENABLE_NEWSLETTER=false
